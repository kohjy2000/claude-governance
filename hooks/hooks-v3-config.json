{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-csv-read.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-claims-source.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-panel-output.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-plan-lock.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-figure-skill.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/track-reads.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-assert-fail.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-panel-review.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-render-candidate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-panel-review.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-figures.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/guard-design-sync.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
